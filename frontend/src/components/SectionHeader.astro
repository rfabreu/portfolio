---
interface Props {
  number: string;
  label: string;
  title: string;
}

const { number, label, title } = Astro.props;
---

<div class="mb-8">
  <div class="font-mono text-accent-indigo text-xs tracking-[3px] mb-2">
    {number} // {label}
  </div>
  <h2 class="text-3xl md:text-4xl font-black" style="letter-spacing: -0.06em;">
    {title}
  </h2>
</div>
